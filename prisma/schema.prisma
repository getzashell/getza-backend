// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  SINGLE
  BUNDLE
  SUBSCRIPTION
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

enum Role {
  USER
  ADMIN
}

enum Jurisdiction {
  UK
  US
  EU
}

enum OutputFormat {
  PDF
  DOCX
  BOTH
}

enum TemplateRenderer {
  HANDLEBARS
}

enum DocumentStatus {
  DRAFT
  FINALIZED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum FileType {
  PDF
  DOCX
}

model Product {
  id             String        @id @default(uuid()) @db.Uuid
  slug           String        @unique
  title          String
  category       String
  subcategory    String?
  descriptionRte Json?
  type           ProductType
  status         ProductStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  templates      Template[]
  stripePrices   StripePrice[]
  orders         Order[]
}

model Template {
  id           String            @id @default(uuid()) @db.Uuid
  productId    String            @db.Uuid
  name         String
  jurisdiction Jurisdiction
  description  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  versions     TemplateVersion[]
}

model TemplateVersion {
  id              String        @id @default(uuid()) @db.Uuid
  templateId      String        @db.Uuid
  version         Int
  inputSchemaJson Json
  promptTemplate  String        @db.Text
  bodyTemplate    String        @db.Text @default("")
  placeholderLegend Json        @default("{}")
  rendererType    TemplateRenderer @default(HANDLEBARS)
  outputFormat    OutputFormat
  isActive        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  lastValidatedAt DateTime?
  lastValidationErrors Json?
  template        Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  documentRuns    DocumentRun[]

  @@unique([templateId, version])
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  passwordHash        String
  name                String?
  role                Role                 @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  orders              Order[]
  documentRuns        DocumentRun[]
  stripeCustomers     StripeCustomer[]
  stripeSubscriptions StripeSubscription[]
}

model DocumentRun {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String?             @db.Uuid
  templateVersionId  String              @db.Uuid
  inputPayload       Json
  draftContent       Json?
  finalContent       Json?
  status             DocumentStatus      @default(DRAFT)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User?               @relation(fields: [userId], references: [id])
  templateVersion    TemplateVersion     @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  generatedDocuments GeneratedDocument[]
}

model GeneratedDocument {
  id            String      @id @default(uuid()) @db.Uuid
  documentRunId String      @db.Uuid
  storageUrl    String?
  fileType      FileType
  createdAt     DateTime    @default(now())
  documentRun   DocumentRun @relation(fields: [documentRunId], references: [id], onDelete: Cascade)
}

model Order {
  id                      String      @id @default(uuid()) @db.Uuid
  userId                  String?     @db.Uuid
  productId               String      @db.Uuid
  stripeCheckoutSessionId String
  stripePaymentIntentId   String?
  status                  OrderStatus @default(PENDING)
  createdAt               DateTime    @default(now())
  user                    User?       @relation(fields: [userId], references: [id])
  product                 Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StripePrice {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  stripePriceId     String   @unique
  currency          String
  unitAmount        Int
  recurringInterval String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StripeCustomer {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StripeSubscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @db.Uuid
  stripeSubscriptionId String    @unique
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  userAgent String?
  ip        String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AppSetting {
  id            String   @id @default(uuid()) @db.Uuid
  developerMode Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}
